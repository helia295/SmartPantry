# Backend (backend/.env or exported shell variables)

# Environment mode
# Use `development` locally and `production` for deployed environments.
# APP_ENV=development

# Database
# Local MVP default:
# DATABASE_URL=sqlite:///./smartpantry.db
# Production example:
# DATABASE_URL=postgresql://user:password@host:5432/smartpantry

# Auth
# Use a long random secret in any non-local environment.
# JWT_SECRET=replace-with-a-strong-secret
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=60

# Frontend origins allowed to call the backend from a browser
# Comma-separated list
# Local development example:
# CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.example
# Production tip:
# Replace localhost entries with the real deployed frontend origin(s).

# Detection
# DETECTION_PROVIDER=yolo
# YOLO_MODEL_NAME=yolov8n.pt
# DETECTION_CONFIDENCE_THRESHOLD=0.35
# YOLO_INFERENCE_SIZE=960
# YOLO_MAX_IMAGE_DIM=1600

# Pantry assistant (backend-only)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5-mini
# OPENAI_ASSISTANT_ENABLED=false
# OPENAI_ASSISTANT_TIMEOUT_SECONDS=20
# OPENAI_ASSISTANT_MAX_RECIPES=5
# OPENAI_ASSISTANT_MAX_PANTRY_ITEMS=25

# Upload limits and retention
# MAX_UPLOAD_IMAGES=3
# MAX_IMAGE_SIZE_MB=5
# IMAGE_RETENTION_DAYS=7
# IMAGE_CLEANUP_INTERVAL_MINUTES=30
# IMAGE_CLEANUP_BATCH_LIMIT=200

# Storage
# `local` is good for local development; prefer `r2` for deployment.
# STORAGE_PROVIDER=local
# LOCAL_STORAGE_DIR=./storage

# Cloudflare R2
# CF_ACCOUNT_ID=
# R2_BUCKET_NAME=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=

# Frontend (frontend/.env.local)
# In deployment, point this at the public backend URL.
# NEXT_PUBLIC_API_URL=http://localhost:8000
